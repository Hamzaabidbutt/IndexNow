# --- Database ---
DATABASE_URL=postgresql://indexjet:indexjet@localhost:5432/indexjet

# --- Redis (queues, rate limiting, realtime events) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
# Generate with: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-64-char-random-hex-string

# --- App ---
APP_URL=http://localhost:3000

# --- IndexNow ---
# Generate with: openssl rand -hex 16
INDEXNOW_KEY=change-me-32-hex-chars

# --- Google Indexing API (optional) ---
# Paste the full service-account JSON on one line, or leave empty to disable
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Admin bootstrap (used by `npm run seed`) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password
