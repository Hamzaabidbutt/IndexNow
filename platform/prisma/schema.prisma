generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================== Users & auth ==============================

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  STARTER
  PRO
  AGENCY
  ENTERPRISE
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(USER)
  plan         Plan      @default(FREE)
  // Billing-ready: credits reset each cycle; Stripe fields prepared but nullable
  credits      Int       @default(50)
  creditsUsed  Int       @default(0)
  cycleEndsAt  DateTime  @default(now())
  stripeCustomerId     String? @unique
  stripeSubscriptionId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  projects Project[]
  apiKeys  ApiKey[]
  auditLogs AuditLog[]
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  // Only a SHA-256 hash is stored; the plaintext key is shown once at creation
  keyHash    String    @unique
  prefix     String // first 12 chars, for display ("ijp_live_ab…")
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

// ============================== Projects & domains ==============================

enum VerificationMethod {
  NONE
  FILE
  DNS
  INDEXNOW_KEY
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  // Apex or full host, e.g. "example.com" or "blog.example.com"
  host      String
  verified           Boolean            @default(false)
  verificationMethod VerificationMethod @default(NONE)
  verificationToken  String             @default(cuid())
  verifiedAt         DateTime?
  // Optional sitemap this project monitors
  sitemapUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  urls Url[]

  @@unique([userId, host])
  @@index([userId])
}

// ============================== URLs & jobs ==============================

enum UrlStatus {
  QUEUED
  PROCESSING
  SUBMITTED // accepted by at least one engine
  DISCOVERED // discovery diagnostics complete (unverified domains)
  FAILED
  CANCELLED
}

enum Priority {
  LOW
  NORMAL
  HIGH
}

model Url {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  status    UrlStatus @default(QUEUED)
  priority  Priority  @default(NORMAL)
  attempts  Int       @default(0)
  lastError String?
  // Per-engine outcome, e.g. {"indexnow": {"status": 202, "at": "..."}}
  engineResults Json?
  submittedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  crawlChecks CrawlCheck[]

  @@unique([projectId, url])
  @@index([projectId, status])
  @@index([status, createdAt])
}

// Crawlability / discovery diagnostics for a URL — one row per run
model CrawlCheck {
  id    String @id @default(cuid())
  urlId String
  url   Url    @relation(fields: [urlId], references: [id], onDelete: Cascade)

  httpStatus     Int?
  redirectChain  Json? // ["https://a", "https://b"]
  responseTimeMs Int?
  etag           String?
  lastModified   String?
  contentType    String?

  robotsAllowed   Boolean?
  metaRobots      String?
  canonicalUrl    String?
  canonicalOk     Boolean?
  title           String?
  h1Count         Int?
  hasStructuredData Boolean?
  htmlValid       Boolean?
  sitemapListed   Boolean?

  // 0–100 crawlability score with per-check breakdown
  score    Int?
  findings Json?

  createdAt DateTime @default(now())

  @@index([urlId, createdAt])
}

// ============================== Audit ==============================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String // e.g. "url.submit", "project.verify", "auth.login"
  detail    Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}
