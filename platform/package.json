{
  "name": "indexjet-platform",
  "version": "1.0.0",
  "private": true,
  "description": "IndexJet — production URL indexing & search engine discovery platform",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "worker": "tsx src/worker/index.ts",
